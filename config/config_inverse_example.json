{
  "_comment": "Inverse Problem: Test heating pattern for target curvature",
  "_use_case": "Given target curvature, optimize line heating pattern on plate",
  
  "out": "results/inverse_curvature_optimization",
  
  "runner": {
    "report_only": false,
    "no_build": false,
    "no_report": false
  },
  
  "simulation": {
