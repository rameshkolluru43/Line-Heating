    ],
    "adjust_for_less_curvature": [
      "Decrease eps0 (0.0025 -> 0.002)",
      "Decrease target_Tmax (950 -> 900)",
      "Increase velocity (faster = less heat input)",
      "Remove passes from heat_y_list"
    ],
    "adjust_for_uniform_curvature": [
