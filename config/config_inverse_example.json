    "bc": "corner_pins",

    "_inherent_strain": "Tune for target curvature magnitude",
    "use_inherent": true,
    "eps0": 0.0025,
    "inh_sigma": 70,
    "inh_zfrac": 0.5,

    "_visualization": "Scale for viewing small deformations",
    "vtk_deform_scale": 5
